#!/bin/bash

MIN_SCREENS=3
BLOCK=10
STATE_DIR="$HOME/.cache/hypr-projects"
PROJECTS_FILE="$STATE_DIR/projects"
CURRENT_FILE="$STATE_DIR/current"
NAMES_FILE="$STATE_DIR/window-names"

mkdir -p "$STATE_DIR"
touch "$PROJECTS_FILE" "$NAMES_FILE"

get_current() {
    cat "$CURRENT_FILE" 2>/dev/null
}

get_start() {
    local name="$1"
    while IFS=$'\t' read -r n s; do
        [ "$n" = "$name" ] && echo "$s" && return
    done < "$PROJECTS_FILE"
}

next_start() {
    local max=0
    while IFS=$'\t' read -r name start; do
        [ "$start" -gt "$max" ] && max="$start"
    done < "$PROJECTS_FILE"
    if [ "$max" -eq 0 ]; then
        echo 1
    else
        echo $((max + BLOCK))
    fi
}

signal_waybar() {
    pkill -RTMIN+11 waybar 2>/dev/null
}

# Switch all monitors to a project's screens (monitor 1→screen 1, monitor 2→screen 2, etc.)
activate_project() {
    local name="$1"
    local start
    start=$(get_start "$name")
    [ -z "$start" ] && return 1

    echo "$name" > "$CURRENT_FILE"

    # Get monitor names sorted by ID
    local monitors
    mapfile -t monitors < <(hyprctl -j monitors 2>/dev/null | jq -r 'sort_by(.id) | .[].name')
    local mon_count=${#monitors[@]}

    if [ "$mon_count" -le 1 ]; then
        # Single monitor: just switch workspace
        hyprctl dispatch workspace "$start" > /dev/null
    else
        # Multi-monitor: batch assign screen per monitor
        local batch=""
        local focused
        focused=$(hyprctl -j monitors 2>/dev/null | jq -r '.[] | select(.focused) | .name')

        for i in "${!monitors[@]}"; do
            local ws=$((start + i))
            local mon="${monitors[$i]}"
            [ "$i" -ge "$BLOCK" ] && break
            batch+="dispatch focusmonitor ${mon}; dispatch workspace ${ws}; "
        done

        # Return focus to the originally focused monitor
        batch+="dispatch focusmonitor ${focused}"
        hyprctl --batch "$batch" > /dev/null
    fi

    signal_waybar
}

# Auto-detect current project from active workspace
sync_from_workspace() {
    local active_ws
    active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq '.id' 2>/dev/null)
    [ -z "$active_ws" ] && return

    while IFS=$'\t' read -r name start; do
        local end=$((start + BLOCK - 1))
        if [ "$active_ws" -ge "$start" ] && [ "$active_ws" -le "$end" ]; then
            echo "$name" > "$CURRENT_FILE"
            return
        fi
    done < "$PROJECTS_FILE"
}

# Auto-create a default project if none exist
ensure_project() {
    local current
    current=$(get_current)
    if [ -z "$current" ] || [ -z "$(get_start "$current")" ]; then
        if [ ! -s "$PROJECTS_FILE" ]; then
            printf '%s\t%s\n' "main" "1" >> "$PROJECTS_FILE"
            echo "main" > "$CURRENT_FILE"
        else
            head -1 "$PROJECTS_FILE" | cut -f1 > "$CURRENT_FILE"
        fi
    fi
}

case "$1" in
    create)
        name="${2:-$(walker -d -I -p "  New project:")}"
        name=$(echo "$name" | xargs)  # trim
        [ -z "$name" ] && exit 1

        # If exists, just switch to it
        existing_start=$(get_start "$name")
        if [ -n "$existing_start" ]; then
            activate_project "$name"
            exit 0
        fi

        start=$(next_start)
        printf '%s\t%s\n' "$name" "$start" >> "$PROJECTS_FILE"
        activate_project "$name"
        ;;

    switch)
        if [ -n "$2" ]; then
            name="$2"
        else
            name=$(cut -f1 "$PROJECTS_FILE" | walker -d -p "  Switch project:")
            name=$(echo "$name" | xargs)
        fi
        [ -z "$name" ] && exit 1

        start=$(get_start "$name")
        [ -z "$start" ] && exit 1

        activate_project "$name"
        ;;

    go)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        hyprctl dispatch workspace "$ws" > /dev/null
        signal_waybar
        ;;

    move)
        screen="$2"
        ensure_project
        current=$(get_current)
        start=$(get_start "$current")
        [ -z "$start" ] && exit 1
        ws=$((start + screen - 1))
        hyprctl dispatch movetoworkspacesilent "$ws" > /dev/null
        signal_waybar
        ;;

    close)
        name="${2:-$(get_current)}"
        [ -z "$name" ] && exit 1

        tmp=$(mktemp)
        while IFS=$'\t' read -r n s; do
            [ "$n" != "$name" ] && printf '%s\t%s\n' "$n" "$s"
        done < "$PROJECTS_FILE" > "$tmp"
        mv "$tmp" "$PROJECTS_FILE"

        if [ "$(get_current)" = "$name" ]; then
            first=$(head -1 "$PROJECTS_FILE" | cut -f1)
            if [ -n "$first" ]; then
                activate_project "$first"
            else
                > "$CURRENT_FILE"
            fi
        fi
        signal_waybar
        ;;

    next)
        current=$(get_current)
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                next_i=$(( (i + 1) % count ))
                name="${names[$next_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    prev)
        current=$(get_current)
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        count=${#names[@]}
        [ "$count" -le 1 ] && exit 0

        for i in "${!names[@]}"; do
            if [ "${names[$i]}" = "$current" ]; then
                prev_i=$(( (i - 1 + count) % count ))
                name="${names[$prev_i]}"
                activate_project "$name"
                exit 0
            fi
        done
        ;;

    switch-index)
        index="$2"
        [ -z "$index" ] && exit 1
        mapfile -t names < <(cut -f1 "$PROJECTS_FILE")
        target="${names[$((index - 1))]}"
        [ -z "$target" ] && exit 0
        activate_project "$target"
        ;;

    list)
        cut -f1 "$PROJECTS_FILE"
        ;;

    current)
        get_current
        ;;

    name)
        # Name the focused window
        addr=$(hyprctl -j activewindow 2>/dev/null | jq -r '.address' 2>/dev/null)
        [ -z "$addr" ] || [ "$addr" = "null" ] && exit 1

        current_name=""
        if [ -f "$NAMES_FILE" ]; then
            current_name=$(grep "^${addr}	" "$NAMES_FILE" | cut -f2)
        fi

        new_name="${2:-$(walker -d -I -p "  Name window:" 2>/dev/null)}"
        new_name=$(echo "$new_name" | xargs)
        [ -z "$new_name" ] && exit 0

        # Remove old entry if exists, add new
        tmp=$(mktemp)
        grep -v "^${addr}	" "$NAMES_FILE" > "$tmp" 2>/dev/null
        printf '%s\t%s\n' "$addr" "$new_name" >> "$tmp"
        mv "$tmp" "$NAMES_FILE"
        signal_waybar
        ;;

    find)
        # Fuzzy search all windows across all projects
        # Build list: "custom_name | app_title · project (screen N)"
        items=""
        while IFS= read -r line; do
            addr=$(echo "$line" | jq -r '.address')
            title=$(echo "$line" | jq -r '.title' | cut -c1-60)
            class=$(echo "$line" | jq -r '.class')
            ws_id=$(echo "$line" | jq -r '.workspace.id')

            # Find which project this workspace belongs to
            proj_name=""
            screen_num=""
            while IFS=$'\t' read -r pname pstart; do
                pend=$((pstart + BLOCK - 1))
                if [ "$ws_id" -ge "$pstart" ] && [ "$ws_id" -le "$pend" ]; then
                    proj_name="$pname"
                    screen_num=$((ws_id - pstart + 1))
                    break
                fi
            done < "$PROJECTS_FILE"

            [ -z "$proj_name" ] && proj_name="untracked" && screen_num="$ws_id"

            # Check for custom name
            custom_name=""
            if [ -f "$NAMES_FILE" ]; then
                custom_name=$(grep "^${addr}	" "$NAMES_FILE" | cut -f2)
            fi

            display_name="${custom_name:-$class}"
            items+="${display_name} | ${title} · ${proj_name} screen ${screen_num}\n"
        done < <(hyprctl -j clients 2>/dev/null | jq -c '.[]')

        [ -z "$items" ] && exit 0

        choice=$(printf "%b" "$items" | walker -d -p "  Find window:")
        [ -z "$choice" ] && exit 0

        # Extract project and screen from the choice
        proj=$(echo "$choice" | grep -oP '· \K[^ ]+(?= screen)')
        scr=$(echo "$choice" | grep -oP 'screen \K[0-9]+')

        if [ -n "$proj" ] && [ -n "$scr" ]; then
            # Switch all monitors to the target project
            activate_project "$proj"

            # Then go to the specific screen and focus the window
            proj_start=$(get_start "$proj")
            if [ -n "$proj_start" ]; then
                ws=$((proj_start + scr - 1))
                hyprctl dispatch workspace "$ws" > /dev/null

                # Find and focus the matching window by title from choice
                win_title=$(echo "$choice" | sed 's/^[^|]*| //' | sed 's/ · .*//')
                hyprctl -j clients | jq -r \
                    ".[] | select(.workspace.id == $ws) | select(.title | startswith(\"$(echo "$win_title" | sed 's/"/\\"/g' | head -c30)\")) | .address" | \
                    head -1 | xargs -I{} hyprctl dispatch focuswindow "address:{}" > /dev/null 2>&1

                signal_waybar
            fi
        fi
        ;;

    waybar)
        sync_from_workspace
        current=$(get_current)

        if [ -z "$current" ]; then
            printf '{"text": "  new", "tooltip": "Click to create a project", "class": "empty"}\n'
            exit 0
        fi

        start=$(get_start "$current")
        active_ws=$(hyprctl -j activeworkspace 2>/dev/null | jq '.id' 2>/dev/null)

        if [ -n "$start" ] && [ -n "$active_ws" ]; then
            screen=$((active_ws - start + 1))
        else
            screen=0
        fi

        # Dynamic dots: show at least MIN_SCREENS, expand if more are occupied
        occupied=$(hyprctl -j workspaces 2>/dev/null | jq -r \
            "[.[] | select(.id >= $start and .id < ($start + $BLOCK)) | .id - $start + 1] | .[]" 2>/dev/null)

        max_screen=$MIN_SCREENS
        for s in $occupied; do
            [ "$s" -gt "$max_screen" ] && max_screen="$s"
        done
        [ "$screen" -gt "$max_screen" ] && max_screen="$screen"

        dots=""
        for i in $(seq 1 $max_screen); do
            if [ "$i" -eq "$screen" ]; then
                dots+=" 󰮯"
            elif echo "$occupied" | grep -qx "$i"; then
                dots+=" 󰊠"
            else
                dots+=" 󰧟"
            fi
        done

        count=$(wc -l < "$PROJECTS_FILE" | xargs)
        current_esc=$(echo "$current" | sed 's/"/\\"/g')

        printf '{"text": "%s%s", "tooltip": "%s  (%s projects)\\nScreen %d of %d\\n\\nClick: switch | Right-click: new | Middle: close\\nScroll: cycle projects", "class": "active"}\n' \
            "$current_esc" "$dots" "$current_esc" "$count" "$screen" "$max_screen"
        ;;

    *)
        echo "Usage: hypr-project {create|switch|go|move|close|next|prev|name|find|list|current|waybar} [args]"
        exit 1
        ;;
esac
